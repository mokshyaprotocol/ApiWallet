    "test:threevenue": "tsx bankrun/threeVenue.test.mjs",
    "test:fee": "tsx bankrun/feeRoute.test.mjs",
    "test:fuzz": "tsx bankrun/fuzz.test.mjs"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.29.0"
  },
  "devDependencies": {
    "@meteora-ag/dlmm": "^1.9.11",
    "@pump-fun/pump-sdk": "^1.36.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "bn.js": "^5.2.4",
    "bs58": "^6.0.0",
    "chai": "^4.3.4",
    "litesvm": "^0.2.0",
    "mocha": "^10.0.0",
    "prettier": "^3.0.0",
    "solana-bankrun": "^0.4.0",
    "ts-mocha": "^10.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0"
  }
