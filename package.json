  "license": "MIT",
  "description": "Secure delegated trading session protocol for Solana",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "anchor test -- --features mock-router",
